# ========================================
# CONFIGURAÇÃO DO FIREBASE EXISTENTE
# ========================================
# O pacote já inclui client/.env.production para o site publicado.
# Use estas variáveis somente em outro ambiente de desenvolvimento.

# Firebase - Credenciais do Projeto
# Obtenha em: https://console.firebase.google.com/ > Project Settings > Your apps
VITE_FIREBASE_API_KEY=sua-api-key-publica-aqui
VITE_FIREBASE_PROJECT_ID=plataforma-enem-f3682
VITE_FIREBASE_APP_ID=seu-app-id-publico-aqui

# ========================================
# COMO OBTER OS SECRETS DO FIREBASE
# ========================================
# 1. Acesse https://console.firebase.google.com/
# 2. Selecione o projeto existente plataforma-enem-f3682
# 3. Clique no ícone de engrenagem (⚙️) > Project Settings
# 4. Role até "Your apps" e selecione seu Web app
# 5. Em "SDK setup and configuration", copie os valores:
#    - apiKey → VITE_FIREBASE_API_KEY
#    - projectId → VITE_FIREBASE_PROJECT_ID
#    - appId → VITE_FIREBASE_APP_ID
#
# 6. Adicione as variáveis ao ambiente de desenvolvimento

# ========================================
# NOTA IMPORTANTE
# ========================================
# DATABASE_URL não é necessário para este projeto.
# O Vestibulando usa Firebase Authentication e Firestore.
# Firebase Storage não é usado.
