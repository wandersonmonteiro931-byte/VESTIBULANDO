# ========================================
# SECRETS OBRIGATÓRIOS PARA O ENEM+
# ========================================
# Configure estes secrets no Replit para o sistema funcionar

# Firebase - Credenciais do Projeto
# Obtenha em: https://console.firebase.google.com/ > Project Settings > Your apps
VITE_FIREBASE_API_KEY=sua-api-key-aqui
VITE_FIREBASE_PROJECT_ID=seu-project-id-aqui
VITE_FIREBASE_APP_ID=seu-app-id-aqui

# ========================================
# COMO OBTER OS SECRETS DO FIREBASE
# ========================================
# 1. Acesse https://console.firebase.google.com/
# 2. Selecione seu projeto (ou crie um novo)
# 3. Clique no ícone de engrenagem (⚙️) > Project Settings
# 4. Role até "Your apps" e selecione seu Web app
# 5. Em "SDK setup and configuration", copie os valores:
#    - apiKey → VITE_FIREBASE_API_KEY
#    - projectId → VITE_FIREBASE_PROJECT_ID
#    - appId → VITE_FIREBASE_APP_ID
#
# 6. No Replit, vá em Tools > Secrets e adicione cada secret

# ========================================
# NOTA IMPORTANTE
# ========================================
# DATABASE_URL não é necessário para este projeto.
# O ENEM+ usa Firebase Firestore como banco de dados.
