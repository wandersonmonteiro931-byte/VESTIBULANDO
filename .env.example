# ========================================
# SECRETS OBRIGATÓRIOS PARA O ENEM+
# ========================================
# Configure estes secrets no Replit para o sistema funcionar

# Firebase - Credenciais do Projeto
# Obtenha em: https://console.firebase.google.com/ > Project Settings > Your apps
VITE_FIREBASE_API_KEY=sua-api-key-aqui
VITE_FIREBASE_AUTH_DOMAIN=seu-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-project-id-aqui
VITE_FIREBASE_MESSAGING_SENDER_ID=seu-messaging-sender-id
VITE_FIREBASE_APP_ID=seu-app-id-aqui

# API Node (nunca use o prefixo VITE_ nestes segredos)
# JSON completo da conta de serviço em uma única linha.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
# Arquivos e o backup compactado mais recente usam blocos no Firestore.
# Não é necessário ativar nem contratar o Firebase Storage.
WEBHOOK_SECRET=gere-um-segredo-longo-e-aleatorio
CRON_SECRET=gere-outro-segredo-longo-e-aleatorio
PUBLIC_FLOW_SECRET=gere-um-terceiro-segredo-com-no-minimo-24-caracteres

# Conectores externos HTTPS/JSON. Configure apenas os serviços contratados.
# Cada endpoint recebe POST autenticado com Bearer TOKEN, Idempotency-Key,
# provider, operation e payload. Os jobs têm fila e até 5 tentativas.
INTEGRATION_EMAIL_ENDPOINT=https://api-do-provedor/email
INTEGRATION_EMAIL_TOKEN=token-secreto-do-provedor
INTEGRATION_PUSH_ENDPOINT=https://api-do-provedor/push
INTEGRATION_PUSH_TOKEN=token-secreto-do-provedor
INTEGRATION_WHATSAPP_ENDPOINT=https://api-do-provedor/whatsapp
INTEGRATION_WHATSAPP_TOKEN=token-secreto-do-provedor
INTEGRATION_PIX_ENDPOINT=https://api-do-provedor/pix
INTEGRATION_PIX_TOKEN=token-secreto-do-provedor
INTEGRATION_BANK_ENDPOINT=https://api-do-provedor/bank
INTEGRATION_BANK_TOKEN=token-secreto-do-provedor
INTEGRATION_INVOICE_ENDPOINT=https://api-do-provedor/invoice
INTEGRATION_INVOICE_TOKEN=token-secreto-do-provedor
INTEGRATION_SIGNATURE_ENDPOINT=https://api-do-provedor/signature
INTEGRATION_SIGNATURE_TOKEN=token-secreto-do-provedor
INTEGRATION_VIDEOCONFERENCE_ENDPOINT=https://api-do-provedor/videoconference
INTEGRATION_VIDEOCONFERENCE_TOKEN=token-secreto-do-provedor
INTEGRATION_GOOGLE_CALENDAR_ENDPOINT=https://api-do-provedor/google-calendar
INTEGRATION_GOOGLE_CALENDAR_TOKEN=token-secreto-do-provedor
INTEGRATION_MICROSOFT_CALENDAR_ENDPOINT=https://api-do-provedor/microsoft-calendar
INTEGRATION_MICROSOFT_CALENDAR_TOKEN=token-secreto-do-provedor
# ========================================
# COMO OBTER OS SECRETS DO FIREBASE
# ========================================
# 1. Acesse https://console.firebase.google.com/
# 2. Selecione seu projeto (ou crie um novo)
# 3. Clique no ícone de engrenagem (⚙️) > Project Settings
# 4. Role até "Your apps" e selecione seu Web app
# 5. Em "SDK setup and configuration", copie os valores:
#    - apiKey → VITE_FIREBASE_API_KEY
#    - projectId → VITE_FIREBASE_PROJECT_ID
#    - appId → VITE_FIREBASE_APP_ID
#
# 6. No Replit, vá em Tools > Secrets e adicione cada secret

# ========================================
# NOTA IMPORTANTE
# ========================================
# DATABASE_URL não é necessário para este projeto.
# O ENEM+ usa Firebase Firestore como banco de dados.
