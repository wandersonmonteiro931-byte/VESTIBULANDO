rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions with null guards
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function userDocExists() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }
    
    function getUserData() {
      return userDocExists() ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data : null;
    }
    
    function isAdmin() {
      return isAuthenticated() && userDocExists() && (
        getUserData().tipo == 'diretor' ||
        (getUserData().keys().hasAny(['papel']) && getUserData().papel == 'administrador') ||
        (getUserData().keys().hasAny(['papelDetalhado']) && getUserData().papelDetalhado == 'administrador')
      );
    }
    
    function isProfessor() {
      return isAuthenticated() && userDocExists() && getUserData().tipo == 'professor';
    }
    
    function isAluno() {
      return isAuthenticated() && userDocExists() && getUserData().tipo == 'aluno';
    }

    function isGuardian() {
      return isAuthenticated() && userDocExists() && getUserData().tipo == 'responsavel';
    }

    function userRole() {
      return getUserData().keys().hasAny(['papelDetalhado'])
        ? getUserData().papelDetalhado
        : (getUserData().keys().hasAny(['papel']) ? getUserData().papel : getUserData().tipo);
    }

    function isInstitutionalStaff() {
      return isAuthenticated() && userDocExists() && userRole() in [
        'diretor', 'administrador', 'secretaria', 'coordenador', 'financeiro',
        'bibliotecario', 'psicologo', 'inspetor', 'funcionario', 'rh', 'cantina', 'transporte'
      ];
    }

    function hasPermission(permission) {
      return isAdmin() || (
        getUserData().keys().hasAny(['permissoes']) &&
        ('*' in getUserData().permissoes || permission in getUserData().permissoes)
      );
    }

    function canManageSchoolModule(moduleId) {
      return isAdmin() || hasPermission(moduleId + '.manage') ||
        (userRole() == 'secretaria' && moduleId in [
          'instituicao', 'acessos', 'alunos', 'responsaveis', 'matriculas',
          'estrutura-academica', 'calendario-horarios', 'documentos-escolares',
          'comunicacao', 'secretaria', 'operacoes', 'lgpd-seguranca'
        ]) ||
        (userRole() == 'coordenador' && moduleId in [
          'estrutura-academica', 'calendario-horarios', 'diario-planejamento',
          'frequencia', 'atividades', 'avaliacoes', 'notas-boletim',
          'acompanhamento', 'conteudos', 'aulas-ao-vivo', 'bem-estar',
          'inclusao', 'relatorios'
        ]) ||
        (userRole() == 'professor' && moduleId in [
          'diario-planejamento', 'frequencia', 'atividades', 'avaliacoes',
          'notas-boletim', 'acompanhamento', 'conteudos', 'aulas-ao-vivo',
          'portal-professor', 'bem-estar'
        ]) ||
        (userRole() == 'professor_substituto' && moduleId in [
          'diario-planejamento', 'frequencia', 'atividades', 'avaliacoes',
          'conteudos', 'aulas-ao-vivo', 'portal-professor', 'bem-estar'
        ]) ||
        (userRole() == 'monitor' && moduleId in ['frequencia', 'atividades', 'conteudos', 'aulas-ao-vivo', 'bem-estar']) ||
        (userRole() == 'financeiro' && moduleId in ['responsaveis', 'matriculas', 'financeiro', 'secretaria', 'relatorios', 'integracoes']) ||
        (userRole() == 'bibliotecario' && moduleId in ['conteudos', 'operacoes']) ||
        (userRole() == 'psicologo' && moduleId in ['acompanhamento', 'bem-estar', 'inclusao']) ||
        (userRole() == 'inspetor' && moduleId in ['frequencia', 'bem-estar', 'operacoes']) ||
        (userRole() == 'aluno' && moduleId in ['portal-aluno', 'secretaria', 'lgpd-seguranca']) ||
        (userRole() == 'responsavel' && moduleId in ['responsaveis', 'portal-responsaveis', 'frequencia', 'secretaria', 'lgpd-seguranca']) ||
        (userRole() == 'funcionario' && moduleId in ['secretaria', 'operacoes']) ||
        (userRole() == 'rh' && moduleId in ['acessos', 'operacoes', 'lgpd-seguranca']) ||
        (userRole() == 'cantina' && moduleId == 'operacoes') ||
        (userRole() == 'transporte' && moduleId in ['bem-estar', 'operacoes']);
    }

    function canReadSchoolFile(fileData) {
      return isAuthenticated() && isUserActive() && (
        isAdmin() ||
        fileData.ownerId == request.auth.uid ||
        (fileData.keys().hasAny(['audienceUserIds']) && request.auth.uid in fileData.audienceUserIds) ||
        (fileData.keys().hasAny(['audienceRoles']) && userRole() in fileData.audienceRoles) ||
        (isAluno() && fileData.keys().hasAny(['studentIds']) && request.auth.uid in fileData.studentIds) ||
        (isAluno() && fileData.keys().hasAny(['classIds']) && getUserData().turma in fileData.classIds)
      );
    }

    function guardianLinkExists(studentId) {
      return isGuardian() && exists(/databases/$(database)/documents/guardianLinks/$(request.auth.uid + '_' + studentId));
    }

    function guardianLink(studentId) {
      return get(/databases/$(database)/documents/guardianLinks/$(request.auth.uid + '_' + studentId)).data;
    }

    function guardianCan(studentId, permission) {
      return guardianLinkExists(studentId) &&
        guardianLink(studentId).active == true &&
        guardianLink(studentId).keys().hasAny(['permissions']) && (
          '*' in guardianLink(studentId).permissions ||
          permission in guardianLink(studentId).permissions
        );
    }

    function isConversationParticipant(conversationId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/chatConversations/$(conversationId)) && (
          get(/databases/$(database)/documents/chatConversations/$(conversationId)).data.participante1Id == request.auth.uid ||
          get(/databases/$(database)/documents/chatConversations/$(conversationId)).data.participante2Id == request.auth.uid
        );
    }
    
    function isUserActive() {
      return userDocExists() && (getUserData().ativo == true || getUserData().ativo == 'true');
    }
    
    function getUserTurma() {
      return userDocExists() ? getUserData().turma : null;
    }
    
    // Usuarios collection
    match /usuarios/{userId} {
      // Qualquer usuário autenticado pode ler dados de outros usuários (necessário para status de presença no chat)
      // Dados sensíveis como CPF são protegidos a nível de aplicação
      allow get: if isAuthenticated();
      
      // O login por CPF/matrícula é resolvido pela API com limitação de
      // tentativas; consultas à coleção completa exigem autenticação.
      allow list: if isAuthenticated();
      
      // Allow creating user doc in two scenarios:
      // 1. Self-registration: User creating their own 'aluno' account
      // 2. Admin creation: Director creating any type of account (approval process)
      allow create: if isAuthenticated() && (
        // Scenario 1: Self-registration (aluno only)
        (request.auth.uid == userId &&
         !exists(/databases/$(database)/documents/usuarios/$(userId)) &&
         request.resource.data.uid == request.auth.uid &&
         request.resource.data.keys().hasAll(['uid', 'nome', 'email', 'tipo', 'ativo']) &&
         request.resource.data.tipo == 'aluno' &&
         request.resource.data.email == request.auth.token.email &&
         request.resource.data.ativo == true) ||
        // Scenario 2: Admin creating account for approval
        (isAdmin() && hasPermission('acessos.manage') &&
         request.resource.data.uid == userId &&
         request.resource.data.keys().hasAll(['uid', 'nome', 'email', 'tipo', 'ativo']))
      );
      
      // Users can update their own presence fields (isOnline, lastSeen, lastActivity, statusPresenca)
      // This is separated to avoid expensive checks during frequent presence updates
      allow update: if isAuthenticated() && request.auth.uid == userId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isOnline', 'lastSeen', 'lastActivity', 'statusPresenca']);
      
      // O próprio usuário altera apenas perfil, preferências e marcadores de
      // segurança. Papéis, permissões, bloqueios, status e validade são administrativos.
      allow update: if isAuthenticated() && (
        (request.auth.uid == userId &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly([
           'uid', 'nome', 'nomeSocial', 'dataNascimento', 'sexo', 'nacionalidade',
           'escolaridade', 'telefone', 'cep', 'rua', 'bairro', 'cidade', 'estado',
           'disponibilidade', 'horarioEspecialObservacao', 'fotoUrl', 'fotoBase64',
           'fotoPublica', 'mensagemStatus', 'preferenciasNotificacao',
           'acessibilidadePreferencias', 'chatTermsAccepted', 'chatTermsAcceptedDate',
           'primeiroAcesso', 'forcarTrocaSenha', 'senhaAlteradaEm', 'mfaAtivado', 'mfaAtivadoEm',
           'mfaDesativadoEm', 'sessoesRevogadasEm', 'sessaoPreservadaId'
         ])) ||
        isAdmin()
      );
      
      // Only admins can delete users
      allow delete: if isAdmin() && hasPermission('acessos.manage');
    }
    
    // Tarefas collection
    match /tarefas/{tarefaId} {
      // Professors can read their own tarefas, alunos can read tarefas for their turma, admins can read all
      allow read: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        (isProfessor() && resource.data.professorId == request.auth.uid) ||
        (isAluno() && resource.data.turma == getUserData().turma) ||
        (isGuardian() &&
          getUserData().keys().hasAny(['filhosTurmasAcademicasIds']) &&
          resource.data.turma in getUserData().filhosTurmasAcademicasIds)
      );
      
      // Only professors can create tarefas
      allow create: if isProfessor() && isUserActive() && 
                       request.resource.data.professorId == request.auth.uid;
      
      // Only the professor who created can update
      allow update: if isProfessor() && isUserActive() && 
                       resource.data.professorId == request.auth.uid;
      
      // Only admins or the professor who created can delete
      allow delete: if isUserActive() && (
        isAdmin() ||
        (isProfessor() && resource.data.professorId == request.auth.uid)
      );
    }
    
    // Entregas collection
    match /entregas/{entregaId} {
      // Helper to check if professor owns the tarefa
      function professorOwnsTarefa(tarefaId) {
        return exists(/databases/$(database)/documents/tarefas/$(tarefaId)) &&
               get(/databases/$(database)/documents/tarefas/$(tarefaId)).data.professorId == request.auth.uid;
      }
      
      // Alunos can read their own entregas, professors can read submissions for their tarefas (via professorId or tarefaId), admins can read all
      allow read: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        (isAluno() && resource.data.alunoId == request.auth.uid) ||
        (isGuardian() && guardianCan(resource.data.alunoId, 'academic.view')) ||
        (isProfessor() && resource.data.professorId == request.auth.uid) ||
        (isProfessor() && professorOwnsTarefa(resource.data.tarefaId))
      );
      
      // Only alunos can create entregas for themselves
      allow create: if isAluno() && isUserActive() && 
                       request.resource.data.alunoId == request.auth.uid;
      
      // Only professors who own the tarefa and admins can update entregas (for grading)
      allow update: if isUserActive() && (
        isAdmin() ||
        (isProfessor() && professorOwnsTarefa(resource.data.tarefaId))
      );
      
      // Only admins can delete entregas
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Turmas collection
    match /turmas/{turmaId} {
      // Anyone can read turmas (needed for registration page)
      allow read: if true;
      
      // Only admins can create turmas
      allow create: if isAdmin() && isUserActive();
      
      // Only admins can update turmas
      allow update: if isAdmin() && isUserActive();
      
      // Only admins can delete turmas
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Solicitacoes collection - for pending user registrations
    match /solicitacoes/{solicitacaoId} {
      // Inscrição, consulta e correção públicas passam pela API limitada e
      // validada. O cliente administrativo mantém acesso integral autenticado.
      allow read, create, update, delete: if isAdmin();
    }
    
    // Reprovacoes collection - for rejected user registrations
    match /reprovacoes/{reprovacaoId} {
      allow read: if isAdmin();
      
      // Only admins can create and update reprovacoes
      allow create: if isAdmin();
      allow update: if isAdmin();
      
      allow delete: if isAdmin();
    }
    
    // Disciplinary Actions collection - advertências e suspensões
    match /disciplinaryActions/{actionId} {
      // Alunos podem ler suas próprias ações disciplinares
      // Diretores podem ler todas as ações disciplinares
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (isAluno() && resource.data.alunoId == request.auth.uid) ||
        (isGuardian() && guardianCan(resource.data.alunoId, 'discipline.view'))
      );
      
      // Apenas diretores podem criar ações disciplinares
      allow create: if isAdmin() && isUserActive() &&
                       request.resource.data.aplicadoPor == request.auth.uid;
      
      // Diretores podem atualizar ações disciplinares (para remover)
      // Alunos podem atualizar apenas o campo visualizado de suas próprias advertências
      allow update: if (isAdmin() && isUserActive()) ||
                       (isAluno() && 
                        resource.data.alunoId == request.auth.uid &&
                        resource.data.tipo == "advertencia" &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['visualizado', 'dataVisualizacao']));
      
      // Apenas diretores podem deletar ações disciplinares
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Disciplinary Requests collection - solicitações de advertências/suspensões por professores e diretores
    match /disciplinaryRequests/{requestId} {
      // Professores podem ler suas próprias solicitações
      // Diretores podem ler todas as solicitações
      allow read: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        (isProfessor() && resource.data.solicitadoPor == request.auth.uid)
      );
      
      // Professores e diretores podem criar solicitações
      allow create: if isUserActive() &&
                       (isProfessor() || isAdmin()) &&
                       request.resource.data.solicitadoPor == request.auth.uid;
      
      // Diretores podem atualizar solicitações (para aprovar/rejeitar)
      // Professores podem atualizar apenas suas próprias solicitações pendentes (para cancelar)
      allow update: if isUserActive() && (
        isAdmin() ||
        (isProfessor() && 
         resource.data.solicitadoPor == request.auth.uid &&
         resource.data.status == "pendente")
      );
      
      // Apenas diretores podem deletar solicitações
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Login History collection - histórico de login/logout
    match /loginHistory/{historyId} {
      // Apenas diretores podem ler o histórico
      allow read: if isAdmin();
      
      // Qualquer usuário autenticado pode criar seu próprio registro
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == request.auth.uid;
      
      // Ninguém pode atualizar ou deletar registros de histórico
      allow update, delete: if false;
    }
    
    // System Maintenance collection - for system maintenance mode
    match /systemMaintenance/{maintenanceId} {
      // Todos podem ler o status de manutenção (para verificar se o sistema está em manutenção)
      allow read: if true;
      
      // Apenas diretores podem criar registros de manutenção
      allow create: if isAdmin() && isUserActive() &&
                       request.resource.data.iniciadoPor == request.auth.uid;
      
      // Apenas diretores podem atualizar registros de manutenção (para finalizar)
      allow update: if isAdmin() && isUserActive();
      
      // Apenas diretores podem deletar registros de manutenção
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Announcements collection - avisos para alunos e professores
    match /announcements/{announcementId} {
      // Todos os usuários autenticados podem ler avisos ativos
      allow read: if isAuthenticated();
      
      // Apenas diretores podem criar avisos
      allow create: if isAdmin() && isUserActive() &&
                       request.resource.data.criadoPor == request.auth.uid;
      
      // Apenas diretores podem atualizar avisos
      allow update: if isAdmin() && isUserActive();
      
      // Apenas diretores podem deletar avisos
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Chat Messages collection
    match /chatMessages/{messageId} {
      // Leitura de mensagem individual (get)
      allow get: if isAuthenticated() && (isAdmin() || isConversationParticipant(resource.data.conversationId));
      
      // A conversa consultada deve pertencer ao usuário; não há listagem global.
      allow list: if isAuthenticated() && (isAdmin() || isConversationParticipant(resource.data.conversationId));
      
      // Apenas usuários autenticados podem criar mensagens
      allow create: if isAuthenticated() && isUserActive() &&
                       request.resource.data.remetenteId == request.auth.uid &&
                       isConversationParticipant(request.resource.data.conversationId);
      
      // Apenas o remetente ou destinatário podem atualizar (para marcar como lida ou deletada)
      allow update: if isAuthenticated() && (isAdmin() || isConversationParticipant(resource.data.conversationId)) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'entregue', 'dataEntrega', 'lida', 'dataLeitura',
          'deletadaPorRemetente', 'deletadaPorDestinatario',
          'dataDeletadaPorRemetente', 'dataDeletadaPorDestinatario',
          'deletadaParaTodos', 'dataDeletadaParaTodos', 'deletadaParaTodosPorId'
        ]);
      
      // Apenas diretores podem deletar mensagens (fisicamente)
      allow delete: if isAdmin();
    }
    
    // Chat Conversations collection
    match /chatConversations/{conversationId} {
      // Apenas participantes da conversa e diretores podem ler
      allow read: if isAuthenticated() && (
        isAdmin() ||
        resource.data.participante1Id == request.auth.uid ||
        resource.data.participante2Id == request.auth.uid
      );
      
      // Usuários autenticados podem criar conversas
      allow create: if isAuthenticated() && isUserActive() && (
        request.resource.data.participante1Id == request.auth.uid ||
        request.resource.data.participante2Id == request.auth.uid
      );
      
      // Apenas participantes podem atualizar conversas
      allow update: if isAuthenticated() && (
        resource.data.participante1Id == request.auth.uid ||
        resource.data.participante2Id == request.auth.uid ||
        isAdmin()
      ) && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'ultimaMensagem', 'ultimaMensagemTimestamp', 'ultimaMensagemRemetenteId',
        'ultimaMensagemEntregue', 'ultimaMensagemLida', 'mensagensNaoLidas1',
        'mensagensNaoLidas2', 'participante1Digitando', 'participante2Digitando',
        'participante1UltimaDigitacao', 'participante2UltimaDigitacao',
        'deletadaPorParticipante1', 'deletadaPorParticipante2',
        'dataDelecaoParticipante1', 'dataDelecaoParticipante2', 'dataUltimaAtualizacao'
      ]);
      
      // Apenas diretores podem deletar conversas
      allow delete: if isAdmin();
    }
    
    // Chat Penalties collection
    match /chatPenalties/{penaltyId} {
      // Usuários podem ler suas próprias penalidades, diretores podem ler todas
      allow read: if isAuthenticated() && (
        isAdmin() ||
        resource.data.usuarioId == request.auth.uid
      );
      
      // Apenas o sistema (via Cloud Functions) ou diretores podem criar penalidades
      allow create: if isAdmin();
      
      // Apenas diretores podem atualizar penalidades (para revisar)
      allow update: if isAdmin() && isUserActive();
      
      // Apenas diretores podem deletar penalidades
      allow delete: if isAdmin();
    }
    
    // User Blocks collection - bloqueios entre usuários
    match /userBlocks/{blockId} {
      // Consultas devem estar limitadas a bloqueios dos quais o usuário participa.
      allow list: if isAuthenticated() && (
        isAdmin() ||
        resource.data.bloqueadorId == request.auth.uid ||
        resource.data.bloqueadoId == request.auth.uid
      );
      
      // Usuários podem ler bloqueios onde são participantes, diretores podem ler todos
      allow get: if isAuthenticated() && (
        isAdmin() ||
        resource.data.bloqueadorId == request.auth.uid ||
        resource.data.bloqueadoId == request.auth.uid
      );
      
      // Usuários autenticados podem criar bloqueios onde são o bloqueador
      allow create: if isAuthenticated() && isUserActive() &&
                       request.resource.data.bloqueadorId == request.auth.uid;
      
      // Apenas o bloqueador pode atualizar (para desbloquear)
      allow update: if isAuthenticated() && isUserActive() &&
                       resource.data.bloqueadorId == request.auth.uid &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ativo', 'dataDesbloqueio']);
      
      // Apenas diretores ou o bloqueador podem deletar
      allow delete: if isAuthenticated() && (
        isAdmin() ||
        resource.data.bloqueadorId == request.auth.uid
      );
    }
    
    // Chat Reports collection - denúncias de conversas
    match /chatReports/{reportId} {
      // Apenas diretores podem ler denúncias
      allow read: if isAdmin();
      
      // Usuários autenticados podem criar denúncias
      allow create: if isAuthenticated() && isUserActive() &&
                       request.resource.data.denuncianteId == request.auth.uid;
      
      // Apenas diretores podem atualizar denúncias (para revisar/resolver)
      allow update: if isAdmin() && isUserActive();
      
      // Apenas diretores podem deletar denúncias
      allow delete: if isAdmin();
    }
    
    // Avaliacoes collection - provas, simulados, atividades, trabalhos
    match /avaliacoes/{avaliacaoId} {
      // Helper to check if user is targeted by the avaliacao
      function isTargetedStudent() {
        return isAluno() && (
          resource.data.turmaId == getUserData().turma ||
          (resource.data.alunosIds != null && request.auth.uid in resource.data.alunosIds)
        );
      }
      
      // Alunos podem ler avaliações da sua turma ou onde são destinatários específicos
      // Professores/Diretores podem ler todas as avaliações
      allow read: if isAuthenticated() && (
        isAdmin() ||
        isProfessor() ||
        isTargetedStudent()
      );
      
      // Professores e diretores podem criar avaliações
      allow create: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        (isProfessor() && request.resource.data.professorId == request.auth.uid)
      );
      
      // Professores podem atualizar suas próprias avaliações, diretores podem atualizar todas
      allow update: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        (isProfessor() && resource.data.professorId == request.auth.uid)
      );
      
      // Apenas diretores ou o professor criador podem deletar
      allow delete: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        (isProfessor() && resource.data.professorId == request.auth.uid)
      );
    }
    
    // Avaliacao Questoes collection - questões das avaliações
    match /avaliacaoQuestoes/{questaoId} {
      // Questões podem ser lidas por professores e diretores
      // Alunos podem ler questões de avaliações às quais têm acesso (verificação via aplicação)
      allow read: if isAuthenticated();
      
      // Professores e diretores podem criar questões
      allow create: if isAuthenticated() && isUserActive() && (isAdmin() || isProfessor());
      
      // Professores e diretores podem atualizar questões
      allow update: if isAuthenticated() && isUserActive() && (isAdmin() || isProfessor());
      
      // Apenas diretores ou professores podem deletar questões
      allow delete: if isAuthenticated() && isUserActive() && (isAdmin() || isProfessor());
    }
    
    // Avaliacao Templates collection - modelos de avaliação
    match /avaliacaoTemplates/{templateId} {
      // Templates podem ser lidos por professores e diretores
      allow read: if isAuthenticated() && (isAdmin() || isProfessor());
      
      // Professores e diretores podem criar templates
      allow create: if isAuthenticated() && isUserActive() && (isAdmin() || isProfessor());
      
      // Professores e diretores podem atualizar templates
      allow update: if isAuthenticated() && isUserActive() && (isAdmin() || isProfessor());
      
      // Apenas diretores podem deletar templates
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Avaliacao Entregas collection - entregas dos alunos
    match /avaliacaoEntregas/{entregaId} {
      // Helper to check if professor owns the avaliacao
      function professorOwnsAvaliacao(avaliacaoId) {
        return exists(/databases/$(database)/documents/avaliacoes/$(avaliacaoId)) &&
               get(/databases/$(database)/documents/avaliacoes/$(avaliacaoId)).data.professorId == request.auth.uid;
      }
      
      // Alunos podem ler suas próprias entregas
      // Professores podem ler entregas das suas avaliações (via professorId ou via avaliacaoId)
      // Diretores podem ler todas as entregas
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (isAluno() && resource.data.alunoId == request.auth.uid) ||
        (isGuardian() && guardianCan(resource.data.alunoId, 'academic.view')) ||
        (isProfessor() && resource.data.professorId == request.auth.uid) ||
        (isProfessor() && professorOwnsAvaliacao(resource.data.avaliacaoId))
      );
      
      // Alunos podem criar entregas para si mesmos
      allow create: if isAluno() && isUserActive() &&
                       request.resource.data.alunoId == request.auth.uid;
      
      // Professores podem atualizar entregas das suas avaliações (para corrigir)
      // Diretores podem atualizar qualquer entrega
      allow update: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        (isProfessor() && professorOwnsAvaliacao(resource.data.avaliacaoId))
      );
      
      // Apenas diretores podem deletar entregas
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Avaliacao Autorizacoes Atraso collection - autorizações para entregas atrasadas
    match /avaliacaoAutorizacoesAtraso/{autorizacaoId} {
      // Alunos podem ler suas próprias autorizações
      // Professores e diretores podem ler todas
      allow read: if isAuthenticated() && (
        isAdmin() ||
        isProfessor() ||
        (isAluno() && resource.data.alunoId == request.auth.uid)
      );
      
      // Alunos podem solicitar autorização
      allow create: if isAluno() && isUserActive() &&
                       request.resource.data.alunoId == request.auth.uid &&
                       request.resource.data.status == 'pendente';
      
      // Professores e diretores podem atualizar (aprovar/rejeitar)
      allow update: if isAuthenticated() && isUserActive() && (isAdmin() || isProfessor());
      
      // Apenas diretores podem deletar
      allow delete: if isAdmin() && isUserActive();
    }
    
    // ==================== BOLETIM ESCOLAR ====================
    
    // Boletins collection - boletins escolares
    match /boletins/{boletimId} {
      // Alunos só podem ver seus próprios boletins liberados
      // Professores e diretores podem ver todos os boletins
      allow read: if isAuthenticated() && (
        isAdmin() ||
        isProfessor() ||
        (isAluno() && resource.data.alunoId == request.auth.uid && resource.data.liberado == true) ||
        (isGuardian() && guardianCan(resource.data.alunoId, 'academic.view') && resource.data.liberado == true)
      );
      
      // Apenas diretores podem criar boletins
      allow create: if isAdmin() && isUserActive();
      
      // Apenas diretores podem atualizar boletins
      allow update: if isAdmin() && isUserActive();
      
      // Apenas diretores podem deletar boletins
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Boletim Configs collection - configurações de liberação
    match /boletimConfigs/{configId} {
      // Diretores podem ler e gerenciar configurações
      // Professores podem apenas ler
      allow read: if isAuthenticated() && (isAdmin() || isProfessor());
      
      // Apenas diretores podem criar/atualizar/deletar
      allow create, update, delete: if isAdmin() && isUserActive();
    }
    
    // Boletim Documentos collection - PDFs dos boletins
    match /boletimDocumentos/{documentoId} {
      // Alunos só podem ver seus próprios documentos de boletins liberados
      // Professores e diretores podem ver todos
      allow read: if isAuthenticated() && (
        isAdmin() ||
        isProfessor() ||
        (isAluno() && resource.data.alunoId == request.auth.uid) ||
        (isGuardian() && guardianCan(resource.data.alunoId, 'academic.view'))
      );
      
      // Apenas diretores podem criar documentos de boletim
      allow create: if isAdmin() && isUserActive();
      
      // Apenas diretores podem atualizar documentos de boletim
      allow update: if isAdmin() && isUserActive();
      
      // Apenas diretores podem deletar documentos de boletim
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Frequencias collection - registros de presença (frequencias e frequencia)
    match /frequencias/{frequenciaId} {
      // Alunos podem ver apenas suas próprias frequências
      // Professores e diretores podem ver todas
      allow read: if isAuthenticated() && (
        isAdmin() ||
        isProfessor() ||
        (isAluno() && resource.data.alunoId == request.auth.uid)
      );
      
      // Professores e diretores podem registrar frequência
      allow create: if isAuthenticated() && isUserActive() && (isAdmin() || isProfessor());
      
      // Professores e diretores podem atualizar frequência
      allow update: if isAuthenticated() && isUserActive() && (isAdmin() || isProfessor());
      
      // Apenas diretores podem deletar frequências
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Frequencia collection (singular) - registros de presença
    match /frequencia/{frequenciaId} {
      // Alunos podem ver apenas suas próprias frequências
      // Professores e diretores podem ver todas
      allow read: if isAuthenticated() && (
        isAdmin() ||
        isProfessor() ||
        (isAluno() && resource.data.alunoId == request.auth.uid)
      );
      
      // Professores e diretores podem registrar frequência
      allow create: if isAuthenticated() && isUserActive() && (isAdmin() || isProfessor());
      
      // Professores e diretores podem atualizar frequência
      allow update: if isAuthenticated() && isUserActive() && (isAdmin() || isProfessor());
      
      // Apenas diretores podem deletar frequências
      allow delete: if isAdmin() && isUserActive();
    }
    
    // ==================== BIMESTRES E NOTAS ====================
    
    // Bimestres Config collection - configuração dos bimestres
    match /bimestresConfig/{configId} {
      // Professores e diretores podem ler configurações
      allow read: if isAuthenticated() && (isAdmin() || isProfessor());
      
      // Apenas diretores podem criar/atualizar/deletar configurações
      allow create: if isAdmin() && isUserActive();
      allow update: if isAdmin() && isUserActive();
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Notas Bimestre collection - notas por bimestre
    match /notasBimestre/{notaId} {
      // Alunos podem ver apenas suas próprias notas
      // Professores e diretores podem ver todas
      allow read: if isAuthenticated() && (
        isAdmin() ||
        isProfessor() ||
        (isAluno() && resource.data.alunoId == request.auth.uid)
      );
      
      // Professores e diretores podem lançar notas
      allow create: if isAuthenticated() && isUserActive() && (isAdmin() || isProfessor());
      
      // Professores e diretores podem atualizar notas
      allow update: if isAuthenticated() && isUserActive() && (isAdmin() || isProfessor());
      
      // Apenas diretores podem deletar notas
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Solicitações de Edição de Nota - solicitações dos professores para alterar notas já entregues
    match /solicitacoesEdicaoNota/{solicitacaoId} {
      // Professores podem ver suas próprias solicitações
      // Diretores podem ver todas as solicitações
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (isProfessor() && resource.data.professorId == request.auth.uid)
      );
      
      // Apenas professores podem criar solicitações para si mesmos
      allow create: if isProfessor() && isUserActive() &&
                       request.resource.data.professorId == request.auth.uid;
      
      // Apenas diretores podem atualizar solicitações (aprovar/rejeitar)
      allow update: if isAdmin() && isUserActive();
      
      // Apenas diretores podem deletar solicitações
      allow delete: if isAdmin() && isUserActive();
    }
    
    // System collection - for counters and system-wide settings
    match /system/{documentId} {
      // Matricula counter can be read by anyone (needed for transactions)
      allow read: if documentId == 'matriculaCounter';
      
      // Write restrictions for matricula counter:
      // - Must include valid timestamp field
      // - Must be exactly +1 increment (no jumps or decrements)
      // - Admins can bypass for maintenance
      // Note: This still allows unauthenticated writes during registration
      // For production, consider moving to Cloud Functions for better security
      allow write: if documentId == 'matriculaCounter' && (
        // Admin override for maintenance
        isAdmin() ||
        // Valid increment with timestamp
        (
          request.resource.data.keys().hasAll(['ultimaMatricula', 'ultimaAtualizacao']) &&
          (
            // First initialization
            !exists(/databases/$(database)/documents/system/matriculaCounter) ||
            // Monotonic increment only
            request.resource.data.ultimaMatricula == resource.data.ultimaMatricula + 1
          )
        )
      );
      
      // Other system documents are admin-only
      allow read, write: if documentId != 'matriculaCounter' && isAdmin();
    }
    
    // ==================== SISTEMA DE HORÁRIOS ====================
    
    // Grade Horária - grade de horários de uma turma
    match /gradesHorarias/{gradeId} {
      // Todos usuários ativos podem ler grades publicadas
      allow read: if isAuthenticated() && isUserActive();
      
      // Apenas diretores podem criar, editar e deletar grades
      allow create, update, delete: if isAdmin() && isUserActive();
    }
    
    // Aulas Agendadas - instâncias de aulas em datas específicas
    match /aulasAgendadas/{aulaId} {
      // Usuários ativos podem ler aulas
      allow read: if isAuthenticated() && isUserActive();
      
      // Diretores podem criar e deletar aulas
      allow create, delete: if isAdmin() && isUserActive();
      
      // Diretores e professores podem atualizar aulas (confirmação de presença)
      allow update: if (isAdmin() || isProfessor()) && isUserActive();
    }
    
    // Presenças em Aulas - registro de presença de alunos
    match /presencasAulas/{presencaId} {
      // Usuários ativos podem ler presenças
      allow read: if isAuthenticated() && isUserActive();
      
      // Diretores podem criar e deletar presenças
      allow create, delete: if isAdmin() && isUserActive();
      
      // Diretores, professores e alunos podem atualizar presenças (confirmar presença)
      allow update: if isAuthenticated() && isUserActive();
    }
    
    // Registro de Presenças em lote - registro de presença por aula/horário
    match /registroPresencas/{registroId} {
      // Usuários ativos podem ler registros de presença
      allow read: if isAuthenticated() && isUserActive();
      
      // Diretores e professores podem criar registros de presença
      allow create: if (isAdmin() || isProfessor()) && isUserActive();
      
      // Diretores e professores podem atualizar registros de presença
      allow update: if (isAdmin() || isProfessor()) && isUserActive();
      
      // Apenas diretores podem deletar registros
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Notificações de Horário - notificações sobre alterações de horário
    match /notificacoesHorarios/{notificacaoId} {
      // Usuários podem ler suas próprias notificações
      allow read: if isAuthenticated() && isUserActive() && (
        resource.data.destinatarioId == request.auth.uid ||
        isAdmin()
      );
      
      // Diretores podem criar notificações
      allow create: if isAdmin() && isUserActive();
      
      // Usuários podem marcar como lida suas próprias notificações
      allow update: if isAuthenticated() && isUserActive() && 
                       resource.data.destinatarioId == request.auth.uid;
      
      // Diretores podem deletar notificações
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Histórico de Grades - histórico de alterações em grades horárias
    match /historicoGrades/{historicoId} {
      // Diretores podem ler o histórico
      allow read: if isAdmin() && isUserActive();
      
      // Diretores podem criar entradas no histórico
      allow create: if isAdmin() && isUserActive();
      
      // Ninguém pode editar ou deletar histórico
      allow update, delete: if false;
    }
    
    // Disponibilidade de Professores - preferências de disponibilidade
    match /disponibilidadeProfessores/{disponibilidadeId} {
      // Diretores e o próprio professor podem ler
      allow read: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        resource.data.professorId == request.auth.uid
      );
      
      // Diretores podem criar disponibilidades
      allow create: if isAdmin() && isUserActive();
      
      // Diretores e o próprio professor podem atualizar
      allow update: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        resource.data.professorId == request.auth.uid
      );
      
      // Diretores podem deletar
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Configuração de Horários - horários personalizáveis de aula
    match /configuracaoHorarios/{configId} {
      // Usuários ativos podem ler configurações de horários
      allow read: if isAuthenticated() && isUserActive();
      
      // Apenas diretores podem criar configurações
      allow create: if isAdmin() && isUserActive();
      
      // Apenas diretores podem atualizar configurações
      allow update: if isAdmin() && isUserActive();
      
      // Apenas diretores podem deletar configurações
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Matérias Customizadas - matérias adicionais cadastradas pelo diretor
    match /materiasCustomizadas/{materiaId} {
      // Usuários ativos podem ler matérias customizadas
      allow read: if isAuthenticated() && isUserActive();
      
      // Apenas diretores podem criar matérias
      allow create: if isAdmin() && isUserActive();
      
      // Apenas diretores podem atualizar matérias
      allow update: if isAdmin() && isUserActive();
      
      // Apenas diretores podem deletar matérias
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Eventos do Calendário - eventos para o calendário de programação
    match /eventosCalendario/{eventoId} {
      // Usuários ativos podem ler eventos
      allow read: if isAuthenticated() && isUserActive();
      
      // Diretores podem criar eventos
      allow create: if isAdmin() && isUserActive();
      
      // Diretores podem atualizar eventos
      allow update: if isAdmin() && isUserActive();
      
      // Diretores podem deletar eventos
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Chamadas Diárias - sessões de presença automática
    match /chamadasDiarias/{chamadaId} {
      // Leitura: diretores podem ler todas, professores só suas próprias, alunos só da sua turma
      allow read: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        (isProfessor() && resource.data.professorId == request.auth.uid) ||
        (isAluno() && resource.data.turmaId == getUserTurma())
      );
      
      // Criação: diretores podem criar qualquer, professores só podem criar com seu próprio professorId
      allow create: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        (isProfessor() && request.resource.data.professorId == request.auth.uid)
      );
      
      // Atualização: professores só podem atualizar suas próprias chamadas
      // E só podem modificar campos de confirmação (professorConfirmou, professorConfirmouEm, professorAusente, status)
      // Campos imutáveis após criação: data, turmaId, turmaNome, horarioId, horarioNome, horarioInicio, horarioFim, materia, professorId, professorNome, limiteConfirmacao, dataCriacao
      allow update: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        (isProfessor() && 
         resource.data.professorId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['professorConfirmou', 'professorConfirmouEm', 'professorAusente', 'status']))
      );
      
      // Apenas diretores podem deletar
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Registros de Presença por Chamada - presença individual de alunos
    match /registrosPresencaChamada/{registroId} {
      // Leitura: alunos só podem ler seus próprios registros, professores e diretores podem ler todos
      allow read: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        isProfessor() ||
        (isAluno() && resource.data.alunoId == request.auth.uid) ||
        (isGuardian() && guardianCan(resource.data.alunoId, 'attendance.view'))
      );
      
      // Apenas diretores e professores podem criar registros
      allow create: if (isAdmin() || isProfessor()) && isUserActive();
      
      // Alunos podem atualizar APENAS seu próprio registro e APENAS campos específicos:
      // - status: "aguardando" -> "presente" (única transição permitida)
      // - confirmadoPeloAluno: false -> true (apenas nesta direção)
      // - dataConfirmacaoAluno: pode ser adicionado
      // - dataAtualizacao: pode ser atualizado
      // NENHUM outro campo pode ser modificado ou adicionado
      // Diretores e professores podem atualizar qualquer registro
      allow update: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        isProfessor() ||
        (isAluno() && 
         resource.data.alunoId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'confirmadoPeloAluno', 'dataConfirmacaoAluno', 'dataAtualizacao', 'browserInfo', 'ipAddress', 'deviceInfo', 'assinaturaDigital', 'geolocalizacao']) &&
         resource.data.status == "aguardando" &&
         request.resource.data.status == "presente" &&
         resource.data.confirmadoPeloAluno == false &&
         request.resource.data.confirmadoPeloAluno == true)
      );
      
      // Apenas diretores podem deletar
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Resumo de Presenças do Dia - estatísticas diárias de presença
    match /resumosPresencaDia/{resumoId} {
      // Usuários podem ler seus próprios resumos, professores e diretores podem ler todos
      allow read: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        isProfessor() ||
        (isAluno() && resource.data.alunoId == request.auth.uid)
      );
      
      // Sistema pode criar e atualizar resumos
      allow create, update: if isAuthenticated() && isUserActive();
      
      // Apenas diretores podem deletar
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Sessões de Aula ao Vivo - sessões de aula em tempo real para controle de presença
    match /sessoesAulaAoVivo/{sessaoId} {
      // Leitura: diretores podem ler todas, professores só suas próprias, alunos só da sua turma
      allow read: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        (isProfessor() && resource.data.professorId == request.auth.uid) ||
        (isAluno() && resource.data.turmaId == getUserTurma())
      );
      
      // Criação: diretores podem criar qualquer, professores só podem criar com seu próprio professorId
      allow create: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        (isProfessor() && request.resource.data.professorId == request.auth.uid)
      );
      
      // Atualização: professores só podem atualizar suas próprias sessões
      // Campos permitidos para atualização: status, dataFim, dataAtualizacao, transmitindoTela, transmitindoCamera, transmitindoAudio, modoVisualizacao
      // Campos imutáveis: turmaId, turmaNome, horarioId, horarioNome, data, professorId, professorNome, materia, dataCriacao, dataInicio, tempoMaxAusencia, tempoInatividade, tempoConfirmacao
      allow update: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        (isProfessor() && 
         resource.data.professorId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'dataFim', 'dataAtualizacao', 'transmitindoTela', 'transmitindoCamera', 'transmitindoAudio', 'modoVisualizacao']))
      );
      
      // Apenas diretores podem deletar
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Live Class Presence collection - presenças em aula ao vivo
    match /presencasAulaAoVivo/{presencaId} {
      allow read: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        isProfessor() ||
        (isAluno() && resource.data.turmaId == getUserTurma())
      );
      allow create: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        isProfessor() ||
        (isAluno() && request.resource.data.alunoId == request.auth.uid)
      );
      allow update: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        isProfessor() ||
        (isAluno() && resource.data.alunoId == request.auth.uid)
      );
      allow delete: if isAdmin() && isUserActive();
    }
    
    // Solicitações de Saída - pedidos de saída da aula
    match /solicitacoesSaida/{solicitacaoId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        isProfessor() ||
        (isAluno() && resource.data.alunoId == request.auth.uid)
      );
      allow create: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        isProfessor() ||
        (isAluno() && request.resource.data.alunoId == request.auth.uid)
      );
      allow update: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        (isProfessor() && resource.data.professorId == request.auth.uid)
      );
      allow delete: if isAdmin() && isUserActive();
    }
    
    // WebRTC Signals - sinalização para videoconferência
    match /webrtcSignals/{signalId} {
      // Professores e alunos podem ler sinais direcionados a eles ou para todos
      allow read: if isAuthenticated() && isUserActive();
      
      // Professores e alunos podem criar sinais
      allow create: if isAuthenticated() && isUserActive() && 
                       request.resource.data.fromUserId == request.auth.uid;
      
      // Professores e alunos podem atualizar sinais (marcar como processado)
      allow update: if isAuthenticated() && isUserActive();
      
      // Apenas admins podem deletar sinais
      allow delete: if isAdmin() && isUserActive();
    }

    // ==================== FINANCEIRO ====================

    // Faturas dos alunos
    match /financialInvoices/{invoiceId} {
      // Diretores podem ver todas; alunos apenas as próprias faturas
      allow read: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        (isAluno() && resource.data.alunoId == request.auth.uid) ||
        (isGuardian() && guardianCan(resource.data.alunoId, 'finance.view'))
      );

      // Apenas a diretoria cria faturas
      allow create: if isAdmin() && isUserActive() &&
        request.resource.data.criadoPor == request.auth.uid;

      // A diretoria gerencia todos os campos.
      // O aluno pode somente anexar/atualizar o comprovante e enviar para análise.
      allow update: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        (isAluno() &&
          resource.data.alunoId == request.auth.uid &&
          request.resource.data.alunoId == resource.data.alunoId &&
          request.resource.data.status == 'em_analise' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'comprovanteUrl',
            'comprovanteNome',
            'comprovanteEnviadoEm',
            'pagamentoInformadoEm',
            'status',
            'atualizadoEm'
          ]))
      );

      allow delete: if isAdmin() && isUserActive();
    }

    // Bolsas de estudo
    match /scholarships/{scholarshipId} {
      allow read: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        (isAluno() && resource.data.alunoId == request.auth.uid) ||
        (isGuardian() && guardianCan(resource.data.alunoId, 'finance.view'))
      );
      allow create, update, delete: if isAdmin() && isUserActive();
    }

    // Configurações de PIX e pagamento
    match /financialSettings/{settingsId} {
      allow read: if isAuthenticated() && isUserActive();
      allow create, update, delete: if isAdmin() && isUserActive();
    }

    // ==================== NÚCLEO ESCOLAR 360 ====================

    // Arquivos em blocos no próprio Firestore. Esta coleção substitui
    // completamente o Firebase Storage e mantém verificação de acesso/hash.
    match /schoolFiles/{fileId} {
      allow get: if canReadSchoolFile(resource.data);
      allow list: if false;
      allow create: if isAuthenticated() && isUserActive() &&
        request.resource.data.ownerId == request.auth.uid &&
        request.auth.uid in request.resource.data.audienceUserIds &&
        request.resource.data.status == 'uploading' &&
        request.resource.data.size is int &&
        request.resource.data.size > 0 &&
        request.resource.data.size <= 8388608 &&
        request.resource.data.chunkCount is int &&
        request.resource.data.chunkCount > 0 &&
        request.resource.data.chunkCount <= 21;
      allow update: if isAuthenticated() && isUserActive() &&
        resource.data.ownerId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'completedAt', 'failedAt']);
      allow delete: if false;

      match /chunks/{chunkId} {
        function parentFile() {
          return get(/databases/$(database)/documents/schoolFiles/$(fileId)).data;
        }
        allow get, list: if parentFile().status == 'ready' && canReadSchoolFile(parentFile());
        allow create: if isAuthenticated() && isUserActive() &&
          parentFile().ownerId == request.auth.uid &&
          request.resource.data.ownerId == request.auth.uid &&
          request.resource.data.fileId == fileId &&
          request.resource.data.index is int &&
          request.resource.data.byteLength is int &&
          request.resource.data.byteLength > 0 &&
          request.resource.data.byteLength <= 409600 &&
          request.resource.data.data is string &&
          request.resource.data.data.size() <= 550000;
        allow update, delete: if false;
      }
    }

    // Vínculos determinísticos entre responsáveis e estudantes.
    match /guardianLinks/{linkId} {
      allow read: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        isInstitutionalStaff() ||
        userRole() in ['professor', 'professor_substituto', 'monitor'] ||
        resource.data.guardianId == request.auth.uid ||
        resource.data.studentId == request.auth.uid
      );
      allow create, update, delete: if isAdmin() && hasPermission('acessos.manage');
    }

    // Registros operacionais dos 30 módulos. Exclusões são sempre lógicas.
    match /schoolRecords/{recordId} {
      allow read: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        request.auth.uid in resource.data.audienceUserIds ||
        userRole() in resource.data.audienceRoles
      );

      allow create: if isAuthenticated() && isUserActive() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.auth.uid in request.resource.data.audienceUserIds &&
        request.resource.data.moduleId is string &&
        request.resource.data.capabilityId is string &&
        request.resource.data.capability is string &&
        request.resource.data.capabilityIndex is int &&
        request.resource.data.customData is map &&
        request.resource.data.automation is map &&
        request.resource.data.title is string &&
        request.resource.data.status is string && (
          canManageSchoolModule(request.resource.data.moduleId)
        );

      allow update: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        canManageSchoolModule(resource.data.moduleId) ||
        resource.data.createdBy == request.auth.uid ||
        resource.data.assigneeId == request.auth.uid
      ) &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.moduleId == resource.data.moduleId &&
        request.resource.data.createdBy == resource.data.createdBy &&
        request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if false;
    }

    // Notas internas ficam separadas do registro compartilhável para evitar exposição.
    match /schoolPrivateNotes/{noteId} {
      allow read: if isAuthenticated() && isUserActive() && (
        isAdmin() ||
        isInstitutionalStaff() ||
        userRole() in ['professor', 'professor_substituto', 'monitor'] ||
        request.auth.uid in resource.data.allowedUserIds
      );
      allow create: if isAuthenticated() && isUserActive() &&
        (isInstitutionalStaff() || userRole() in ['professor', 'professor_substituto', 'monitor']) &&
        request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    // Auditoria imutável. Cada ator pode gravar sua própria ação; leitura global é restrita.
    match /schoolAuditLogs/{auditId} {
      allow get: if isAuthenticated() && isUserActive() && (
        isAdmin() || resource.data.actorId == request.auth.uid
      );
      allow list: if isAdmin() && isUserActive();
      allow create: if isAuthenticated() && isUserActive() &&
        request.resource.data.actorId == request.auth.uid &&
        request.resource.data.immutable == true;
      allow update, delete: if false;
    }

    // Central de notificações em tempo real, sem consultas periódicas.
    match /schoolNotifications/{notificationId} {
      allow read: if isAuthenticated() && isUserActive() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isUserActive() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && isUserActive() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);
      allow delete: if isAdmin();
    }

    // Validação pública expõe somente metadados mínimos, nunca o prontuário completo.
    match /schoolDocumentValidations/{validationId} {
      allow read: if true;
      allow create, update: if isAuthenticated() && isUserActive() && (
        isAdmin() || hasPermission('documentos-escolares.manage')
      );
      allow delete: if false;
    }

    // Metadados dos backups automáticos e dos testes de recuperação. Somente o
    // backend grava; a direção pode acompanhar o resultado no painel.
    match /schoolBackups/{backupId} {
      allow read: if isAdmin() && isUserActive();
      allow write: if false;

      match /chunks/{chunkId} {
        allow read: if isAdmin() && isUserActive();
        allow write: if false;
      }
    }

    match /schoolBackupTests/{testId} {
      allow read: if isAdmin() && isUserActive();
      allow write: if false;
    }

    // Alertas automáticos gerados pelo backend (por exemplo, excesso de
    // tentativas). Somente a direção pode consultá-los.
    match /securityAlerts/{alertId} {
      allow read: if isAdmin() && isUserActive();
      allow write: if false;
    }
  }
}
